# Copy to .env.local and fill in ONE of the keys below.
# Without any key, /api/ask returns a mock response.

# Option A (free, no card): Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Option B (paid, pennies/month): Anthropic key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: force a provider ("gemini" or "anthropic").
# If unset, auto-detects: GEMINI_API_KEY wins if both are set.
AI_PROVIDER=
